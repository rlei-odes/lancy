# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Password to access the RAG Assistant UI
API_KEY=your-secret-password

# Backend URL used server-side by the Next.js proxy (never reaches the browser)
BACKEND_URL=http://localhost:8080

# SERVER_URL: browser-side API base URL.
# Leave EMPTY — the frontend uses relative URLs through the Next.js proxy.
# Setting this to a hostname causes API calls to resolve from the client machine,
# which breaks access from other devices on the same network.
SERVER_URL=
