# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Password to access the RAG Assistant UI (becomes the user password in Mode 2)
APP_PASSWORD=your-secret-password

# Optional: admin password for role separation (Mode 2).
# Can also be set via the Settings UI — which writes to auth_config.json instead.
# ADMIN_PASSWORD=your-admin-password

# Backend URL used server-side by the Next.js proxy (never reaches the browser)
BACKEND_URL=http://localhost:8080

# SERVER_URL: browser-side API base URL.
# Leave EMPTY — the frontend uses relative URLs through the Next.js proxy.
# Setting this to a hostname causes API calls to resolve from the client machine,
# which breaks access from other devices on the same network.
SERVER_URL=
