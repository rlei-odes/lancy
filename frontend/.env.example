# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Password to access the RAG Assistant UI (becomes the user password in Mode 2)
APP_PASSWORD=your-secret-password

# Optional: admin password for role separation (Mode 2).
# Can also be set via the Settings UI — which writes to auth_config.json instead.
# Precedence for browser login: auth_config.json wins over this value if both are set.
# For API access (Bearer token): only this env var is checked — auth_config.json is not
# readable in the Edge Runtime. If you need Bearer token admin access, set it here.
# ADMIN_PASSWORD=your-admin-password

# Backend URL used server-side by the Next.js proxy (never reaches the browser)
BACKEND_URL=http://localhost:8080
